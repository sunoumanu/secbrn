# ─── Neo4j ────────────────────────────────────────────────────────────────────
SECBRN_NEO4J_URI=bolt://localhost:7687
SECBRN_NEO4J_USER=neo4j
SECBRN_NEO4J_PASSWORD=secbrnsecbrn
SECBRN_NEO4J_DATABASE=neo4j

# ─── Model providers ────────────────────────────────────────────────────────────
# provider: "ollama" (default), "fake" (offline tests, deterministic)
SECBRN_PROVIDER=ollama
SECBRN_OLLAMA_BASE_URL=http://localhost:11434

# Ollama HTTP resilience — raise these for big PDFs / slow CPUs to avoid ReadTimeout.
SECBRN_OLLAMA_EMBED_TIMEOUT=180     # seconds per embedding call
SECBRN_OLLAMA_LLM_TIMEOUT=600       # seconds per generation call
SECBRN_OLLAMA_MAX_RETRIES=3         # retry transient timeouts before giving up
SECBRN_OLLAMA_RETRY_BACKOFF=2       # exponential backoff base (seconds)

# Graph store backend (decoupled from provider):
#   auto   = memory iff provider==fake, else neo4j
#   neo4j  = always persist to Neo4j   |   memory = in-process only (NOT persisted)
# If you don't see data in Neo4j, make sure this is "neo4j" (or "auto" with provider!=fake).
SECBRN_GRAPH_BACKEND=auto

# Embeddings (dim MUST match the Neo4j vector index — see SCHEMA.md)
SECBRN_EMBED_MODEL=nomic-embed-text
SECBRN_EMBED_DIM=768

# LLMs — extraction may use a stronger/slower model than answering (ingest is offline)
SECBRN_EXTRACT_MODEL=llama3.1:8b
SECBRN_ANSWER_MODEL=llama3.1:8b

# ─── Chunking ─────────────────────────────────────────────────────────────────
SECBRN_CHUNK_SIZE=900
SECBRN_CHUNK_OVERLAP=120

# ─── Entity resolution thresholds (Stage 6) ───────────────────────────────────
SECBRN_RES_SIMILARITY_THRESHOLD=0.86
SECBRN_RES_WORD_DISTANCE=2
SECBRN_RES_EMBED_CUTOFF=0.90
SECBRN_RES_LLM_MARGIN=0.08

# ─── Retrieval ────────────────────────────────────────────────────────────────
SECBRN_RETRIEVE_TOP_K=6
SECBRN_RETRIEVE_HOPS=2
# Graph-aware scoring: boost chunks whose entities are near the query's entities (0=off)
SECBRN_GRAPH_BOOST=0.5
# Lexical boost when query terms appear in a chunk's document title / heading (0=off)
SECBRN_TITLE_BOOST=0.4
